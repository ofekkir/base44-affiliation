# ── Analytics (all optional) ─────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=            # Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GA_ID=             # GA4 Measurement ID (optional, can use via GTM instead)
NEXT_PUBLIC_HOTJAR_ID=         # Hotjar Site ID (e.g. 1234567)

# ── Collector ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_COLLECTOR_URL=     # Deployed collector base URL (e.g. https://your-collector.vercel.app)
NEXT_PUBLIC_PRODUCT_NAME=HoopoeApps
NEXT_PUBLIC_PRODUCT_SLUG=hoopoeapps
NEXT_PUBLIC_CAMPAIGN_SLUG=hoopoeapps_launch
NEXT_PUBLIC_PAGE_VARIANT_ID=   # Generate one: node -e "console.log(require('crypto').randomUUID())"

# ── Affiliate ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE44_AFFILIATE_URL=  # Your Base44 affiliate tracking URL
