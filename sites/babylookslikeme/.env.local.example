# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
# GA4 + Microsoft Clarity are configured inside GTM
# via the google/setup-gtm.ts script
NEXT_PUBLIC_GTM_ID=

# Base44 affiliate tracking code (the `e=` query param).
# The app-building prompt is hardcoded in lib/analytics.ts and does not need env config.
NEXT_PUBLIC_BASE44_AFFILIATE_CODE=
