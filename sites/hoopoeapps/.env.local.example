# ── Email (required) ──────────────────────────────────────────────────────
RESEND_API_KEY=                # Get from resend.com — verify hoopoeapps.com domain first

# ── Analytics ────────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=            # Google Tag Manager container ID (e.g. GTM-XXXXXXX)
                               # GA4 + Microsoft Clarity are configured inside GTM
                               # via the google/setup-gtm.ts script

# ── Affiliate ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE44_AFFILIATE_URL=  # Your Base44 affiliate tracking URL
