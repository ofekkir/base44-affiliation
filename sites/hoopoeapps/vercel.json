{
  "rewrites": [
    {
      "source": "/babylook",
      "destination": "https://babylookslikeme.vercel.app/babylook"
    },
    {
      "source": "/babylook/:path*",
      "destination": "https://babylookslikeme.vercel.app/babylook/:path*"
    },
    {
      "source": "/buildyourapp",
      "destination": "https://base44-app-quiz.vercel.app"
    },
    {
      "source": "/buildyourapp/:path*",
      "destination": "https://base44-app-quiz.vercel.app/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
