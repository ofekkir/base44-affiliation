# ── Google OAuth (reuse from yb4) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Account IDs ──────────────────────────────────────────────────────────
GTM_ACCOUNT_ID=                        # tagmanager.google.com → Admin → Account Settings
GA_ACCOUNT_ID=                         # analytics.google.com → Admin → Account Settings

# ── Microsoft Clarity (create projects at clarity.microsoft.com) ─────────
# Clarity has no API for project creation — create manually, paste IDs here.
CLARITY_PROJECT_ID_HOOPOEAPPS=         # e.g. abc123xyz
CLARITY_PROJECT_ID_BABYLOOKSLIKEME=    # e.g. abc123xyz

# ── Optional: reuse existing resources instead of creating new ones ──────
# GTM_CONTAINER_ID_HOOPOEAPPS=         # e.g. GTM-XXXXXXX
# GTM_CONTAINER_ID_BABYLOOKSLIKEME=    # e.g. GTM-XXXXXXX
# GA4_MEASUREMENT_ID_HOOPOEAPPS=       # e.g. G-XXXXXXXXXX
# GA4_MEASUREMENT_ID_BABYLOOKSLIKEME=  # e.g. G-XXXXXXXXXX
